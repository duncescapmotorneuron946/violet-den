# ─────────────────────────────────────────────────────────────
# VioletDen — Environment Configuration
# Copy to .env and edit as needed:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Admin credentials (used as defaults until changed via UI) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Ports ──
BACKEND_PORT=4000
HTTP_PORT=80
HTTPS_PORT=443

# ── CORS (comma-separated origins; omit for permissive dev mode) ──
# CORS_ORIGINS=https://home.local,https://192.168.1.100

# ── Preset sections (JSON) — pre-populates the onboarding wizard ──
# These are only used for the initial onboarding autocomplete.
# After first setup, sections are stored in SQLite.
VITE_PRESET_SECTIONS=[{"title":"Network & Routers","icon":"router","links":[{"name":"Main Router","url":"http://192.168.88.1","icon":"router"},{"name":"LTE Router","url":"http://192.168.100.1","icon":"wifi"}]},{"title":"Servers","icon":"dns","links":[{"name":"Smart Home Server","url":"http://192.168.1.10:9090","icon":"computer"},{"name":"NAS Admin","url":"http://192.168.1.20","icon":"storage"}]},{"title":"Home Automation","icon":"home","links":[{"name":"Home Assistant","url":"http://192.168.1.50:8123","icon":"smart_toy"},{"name":"Pi-hole","url":"http://192.168.1.60","icon":"shield"},{"name":"Unifi","url":"http://192.168.1.70","icon":"hub"}]},{"title":"Media","icon":"live_tv","links":[{"name":"Radarr","url":"http://192.168.1.80:7878","icon":"movie"},{"name":"Sonarr","url":"http://192.168.1.81:8989","icon":"tv"},{"name":"qBittorrent","url":"http://192.168.1.83:8080","icon":"download"}]}]
